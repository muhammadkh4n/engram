{
  "name": "@engram-mem/bench",
  "version": "0.3.5",
  "description": "Benchmark harness for Engram — LoCoMo and LongMemEval evaluation with comparison mode",
  "keywords": [
    "memory",
    "ai",
    "agents",
    "cognitive",
    "embeddings",
    "recall",
    "benchmark",
    "locomo",
    "evaluation"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "engram-bench": "dist/bin/engram-bench.js",
    "engram-bench-judge": "dist/bin/engram-bench-judge.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@engram-mem/core": "*",
    "@engram-mem/sqlite": "*",
    "@engram-mem/openai": "*",
    "@engram-mem/rerank-onnx": "*"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "@types/node": "^25.6.0"
  }
}
