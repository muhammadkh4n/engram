{
  "name": "@engram-mem/mcp",
  "version": "0.6.4",
  "description": "MCP server for Engram memory — recall, ingest, forget, timeline, overview tools for Claude Code and any MCP client",
  "keywords": [
    "memory",
    "ai",
    "agents",
    "cognitive",
    "embeddings",
    "recall",
    "mcp",
    "claude",
    "tools"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "engram-mcp": "dist/index.js",
    "engram-mcp-http": "dist/index-http.js",
    "engram-dream-cycle": "dist/dream-cycle-cli.js",
    "engram-session-summary": "dist/session-summary.js",
    "engram-pre-compact": "dist/pre-compact.js",
    "engram-backfill-graph": "dist/backfill-graph.js",
    "engram-test-wave2-e2e": "dist/test-wave2-e2e.js",
    "engram-ingest": "dist/ingest/engram-ingest-cli.js",
    "engram-contextual-backfill": "dist/ingest/engram-contextual-backfill-cli.js",
    "engram-embed-backfill": "dist/ingest/engram-embed-backfill-cli.js",
    "engram-hook-user-prompt-submit": "dist/hooks/user-prompt-submit.js",
    "engram-hook-stop": "dist/hooks/stop.js",
    "engram-salience-stats": "dist/ingest/engram-salience-stats-cli.js",
    "engram-git-setup": "dist/git-setup-cli.js",
    "engram-shell-setup": "dist/shell-setup-cli.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammadkh4n/engram.git"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@engram-mem/core": "*",
    "@engram-mem/graph": "*",
    "@engram-mem/openai": "*",
    "@engram-mem/postgrest": "0.5.2",
    "@engram-mem/recall-engine": "*",
    "@engram-mem/rerank-onnx": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/postgrest-js": "^2.110.7",
    "openai": "^6.48.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
}
