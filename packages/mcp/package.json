{
  "name": "@engram-mem/mcp",
  "version": "0.1.1",
  "type": "module",
  "description": "MCP server exposing Engram memory tools for Claude Code and other MCP clients",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "engram-mcp": "dist/index.js",
    "engram-session-summary": "dist/session-summary.js",
    "engram-pre-compact": "dist/pre-compact.js",
    "engram-backfill-graph": "dist/backfill-graph.js",
    "engram-test-wave2-e2e": "dist/test-wave2-e2e.js",
    "engram-ingest": "dist/ingest/engram-ingest-cli.js"
  },
  "files": ["dist/", "README.md"],
  "publishConfig": { "access": "public" },
  "repository": { "type": "git", "url": "https://github.com/muhammadkh4n/engram.git" },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@engram-mem/core": "*",
    "@engram-mem/graph": "*",
    "@engram-mem/openai": "*",
    "@engram-mem/supabase": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.45.0",
    "openai": "^4.60.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
