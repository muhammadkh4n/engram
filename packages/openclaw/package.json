{
  "name": "@engram-mem/openclaw",
  "version": "0.1.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist/", "README.md", "openclaw.plugin.json"],
  "publishConfig": { "access": "public" },
  "repository": { "type": "git", "url": "https://github.com/muhammadkh4n/engram.git" },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin": {
      "import": "./dist/openclaw-plugin.js"
    }
  },
  "scripts": {
    "build": "tsc && tsup",
    "build:plugin": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@engram-mem/core": "*",
    "@engram-mem/openai": "*",
    "@engram-mem/sqlite": "*",
    "@engram-mem/supabase": "*",
    "@sinclair/typebox": "^0.34.49"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
